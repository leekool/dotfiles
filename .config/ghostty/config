theme = Kanagawa Wave

font-family = JetBrainsMono NF Medium
font-family-bold = JetBrainsMono NF Bold
font-family-italic = JetBrainsMono NF Medium Italic
font-family-bold-italic = JetBrainsMono NF Bold Italic
font-size = 11

background-opacity = 0.92

window-padding-x = 9
window-padding-y = 8,0

window-decoration = server 
window-theme = ghostty
window-show-tab-bar = auto
gtk-single-instance = false

confirm-close-surface = false

gtk-titlebar = true
gtk-titlebar-style = native
gtk-tabs-location = top
gtk-toolbar-style = flat
gtk-wide-tabs = false
gtk-custom-css = /home/lee/.config/ghostty/theme.css

keybind = ctrl+backspace=text:\x17
keybind = ctrl+a>h=new_split:down
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>s=toggle_tab_overview
keybind = ctrl+a>x=equalize_splits
keybind = ctrl+a>w=close_surface
keybind = ctrl+a>left=goto_split:left
keybind = ctrl+a>right=goto_split:right
keybind = ctrl+a>up=goto_split:up
keybind = ctrl+a>down=goto_split:down
keybind = ctrl+a>.=resize_split:right,10
keybind = ctrl+a>,=resize_split:left,10
keybind = shift+enter=text:\x1b\x0d
